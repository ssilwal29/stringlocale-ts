{
  "name": "stringlocale-simple-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "i18n": "tsx ../../src/cli/index.ts compile --sources src/strings.ts --source-locale en-US --locales ne-NP nl-NL ar-SA --out public/i18n",
    "i18n:check": "tsx ../../src/cli/index.ts check --sources src/strings.ts --out public/i18n",
    "i18n:prune": "tsx ../../src/cli/index.ts prune --sources src/strings.ts --out public/i18n",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "stringlocale": "file:../.."
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0"
  }
}
