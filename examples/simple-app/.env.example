# Copy to .env.local and add your key to enable the "Live translate" card.
# Dev-only: Vite inlines VITE_* vars into the browser bundle, so never use a
# production key here — proxy through your own backend instead.
VITE_TRANSLATION_API_KEY=your-api-key
# Optional: any OpenAI-compatible chat-completions endpoint.
# If omitted, defaults to OpenRouter.
VITE_TRANSLATION_ENDPOINT=https://openrouter.ai/api/v1/chat/completions

# Backward-compatible aliases:
# VITE_OPENROUTER_API_KEY=sk-or-...
# VITE_OPENROUTER_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
